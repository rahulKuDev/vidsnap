# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# ── Database ──────────────────────────────────────────────────────────────────
# Path to store SQLite DB — mount a Railway Volume at this path for persistence
DB_DIR=/app/data

# ── File Storage ──────────────────────────────────────────────────────────────
DOWNLOADS_DIR=/app/downloads
UPLOADS_DIR=/app/uploads

# ── Email (for OTP verification) ─────────────────────────────────────────────
# Use Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=VidSnap <your-email@gmail.com>

# ── CORS (set to your frontend Railway URL) ───────────────────────────────────
# e.g: ALLOWED_ORIGINS=https://vidsnap-frontend.up.railway.app
ALLOWED_ORIGINS=*

# ── yt-dlp ────────────────────────────────────────────────────────────────────
YTDLP_PATH=/usr/local/bin/yt-dlp
