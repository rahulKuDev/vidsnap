# Server
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# App URLs
# Use your Vercel frontend URL in production.
APP_URL=https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Security
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# Render persistent disk paths
DB_DIR=/app/persist/data
DOWNLOADS_DIR=/app/persist/downloads
UPLOADS_DIR=/app/persist/uploads

# Local Docker/non-Render default for yt-dlp
YTDLP_PATH=/usr/local/bin/yt-dlp

# Email for OTP verification and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=VidSnap
