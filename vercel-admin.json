{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "artifacts/admin-panel",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://vidsnap-api.onrender.com/api/:match*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
